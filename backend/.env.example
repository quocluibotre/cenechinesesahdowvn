PORT=3000

# Comma-separated whitelist origins for CORS
# Example: https://your-app.pages.dev,https://preview.yourdomain.dev
CORS_ORIGINS=
CORS_ORIGIN_SUFFIXES=
FRONTEND_URL=
FRONTEND_URLS=

# mysql | postgres (Supabase)
DB_CLIENT=mysql

DB_HOST=localhost
DB_PORT=3306
DB_NAME=if0_41324441_cineshadow
DB_USER=root
DB_PASSWORD=your_db_password

# Optional for PostgreSQL/Supabase (recommended)
# DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
# DB_SSL=true
# DB_CONNECTION_LIMIT=10

JWT_SECRET=your_jwt_secret

# Cloudflare R2 settings
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=your_bucket_name
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# Gemini LLM for vocabulary generation
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest
GEMINI_CHUNK_SIZE=10
GEMINI_REQUEST_DELAY_MS=4200
GEMINI_MAX_RETRIES=2

# Vocabulary generation mode
# fast   = extract vocabulary directly from subtitles (no Gemini required)
# auto   = try Gemini first, fallback to fast on quota/errors
# gemini = force Gemini only
VOCAB_GENERATION_ENGINE=fast
# Only used by gemini/auto path
VOCAB_GEMINI_MAX_SUBTITLE_PAIRS=120

# YouTube subtitle translation engine
# fast   = quick machine translation (no GEMINI_API_KEY required)
# gemini = higher contextual quality but slower and requires GEMINI_API_KEY
# Optional but recommended for richer metadata in /api/youtube/process.
# If missing, backend will fallback to oEmbed/watch-page metadata parsing.
YOUTUBE_API_KEY=
# Optional outbound proxy for YouTube requests (helps with Render IP/rate-limit/region blocks)
# Supported formats:
# - http://username:password@proxy-host:port
# - https://username:password@proxy-host:port
# - username:password@proxy-host:port (auto add http://)
# - proxy-host:port (no auth)
YOUTUBE_PROXY_URL=
YOUTUBE_TRANSLATE_ENGINE=fast
YOUTUBE_TRANSLATE_CONCURRENCY=6
YOUTUBE_TRANSLATE_TIMEOUT_MS=12000
# Number of subtitle lines translated together to preserve context (fast engine)
# 1 = line-by-line (old behavior), 3-6 = more contextual
YOUTUBE_TRANSLATE_CONTEXT_GROUP=4
# Idiom/slang post-edit mode for unknown phrases
# off    = disable idiom auto rewrite
# auto   = try Gemini idiom rewrite only when GEMINI_API_KEY exists, skip silently on errors
# gemini = force Gemini idiom rewrite (still skips if request fails)
YOUTUBE_IDIOM_REWRITE_ENGINE=auto
# Max subtitle lines per batch to idiom-refine
YOUTUBE_IDIOM_REWRITE_MAX_ITEMS=20
# Optional dedicated model for idiom refinement
# YOUTUBE_IDIOM_REWRITE_MODEL=gemini-2.0-flash
# Optional custom endpoint for fast mode
# YOUTUBE_TRANSLATE_ENDPOINT=https://translate.googleapis.com/translate_a/single

# Optional defaults for local subtitle import script (scripts/import_subtitles_local.js)
# SUBTITLE_SOURCE_TRACK=chinese|english
# SUBTITLE_LANG=zh-Hans|en|...
SUBTITLE_SOURCE_TRACK=
SUBTITLE_LANG=
# Auto-fix mixed/garbled local-AI subtitle lines with fast fallback
LOCAL_AI_REPAIR_MIXED_TRANSLATION=true
LOCAL_AI_REPAIR_TIMEOUT_MS=12000
LOCAL_AI_REPAIR_MAX_LINES=200

# Backend TTS pronunciation cache
TTS_CACHE_TTL_MS=86400000
TTS_CACHE_MAX_ITEMS=500
