PORT=3000

# Comma-separated whitelist origins for CORS
# Example: https://your-app.pages.dev,https://preview.yourdomain.dev
CORS_ORIGINS=
CORS_ORIGIN_SUFFIXES=
FRONTEND_URL=
FRONTEND_URLS=

# mysql | postgres (Supabase)
DB_CLIENT=mysql

DB_HOST=localhost
DB_PORT=3306
DB_NAME=if0_41324441_cineshadow
DB_USER=root
DB_PASSWORD=your_db_password

# Optional for PostgreSQL/Supabase (recommended)
# DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
# DB_SSL=true
# DB_CONNECTION_LIMIT=10

JWT_SECRET=your_jwt_secret

# Cloudflare R2 settings
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=your_bucket_name
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# Gemini LLM for vocabulary generation
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest
GEMINI_CHUNK_SIZE=10
GEMINI_REQUEST_DELAY_MS=4200
GEMINI_MAX_RETRIES=2

# Backend TTS pronunciation cache
TTS_CACHE_TTL_MS=86400000
TTS_CACHE_MAX_ITEMS=500
